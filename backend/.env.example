# ==============================================================================
# INDUS BRAIN AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# FastAPI Application Settings
PROJECT_NAME="INDUS BRAIN AI"
HOST="0.0.0.0"
PORT=8000

# SQLite Database Location
DATABASE_URL="sqlite:///./indus_brain.db"

# Security Configurations
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET="supersecretindustrialbrainapikey2026key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 Days in minutes

# AI & Embedding Model Parameters
# Get your Gemini API Key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Local vector storage path and model name
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
FAISS_INDEX_PATH="./faiss_index"
